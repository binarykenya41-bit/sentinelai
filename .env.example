# ============================================================
# SENTINELAI — ENVIRONMENT VARIABLES TEMPLATE
# Copy to .env and fill in your credentials. Never commit .env
# ============================================================

# ------------------------------------------------------------
# SUPABASE
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_JWT_SECRET=
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ------------------------------------------------------------
# FRONTEND
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://bears-sydney-ssl-ate.trycloudflare.com
NEXT_PUBLIC_API_URL=https://gray-discovered-mud-premiere.trycloudflare.com

# ------------------------------------------------------------
# BACKEND
# ------------------------------------------------------------
BACKEND_PORT=8000
BACKEND_SECRET_KEY=change-in-production
BACKEND_CORS_ORIGINS=http://localhost:3000

# ------------------------------------------------------------
# AI LAYER — Anthropic Claude
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# THREAT INTELLIGENCE APIs
# ------------------------------------------------------------
# NVD API key (free — raises rate limit from 5 to 50 req/30s)
# Get at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# EPSS — no key needed (public FIRST API)
# CISA KEV — no key needed (public JSON feed)
# MITRE ATT&CK TAXII — no key needed (public)

# ------------------------------------------------------------
# REDIS (for caching CVE/EPSS data)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# EXPLOIT SIMULATION SANDBOX
# ------------------------------------------------------------
# Docker network name for isolated sandbox containers
SANDBOX_NETWORK=sentinel-sandbox
# Sandbox API URL (for Firecracker fleet in production)
EXPLOIT_LAB_SANDBOX_URL=http://localhost:9000
EXPLOIT_LAB_SECRET=change-in-production

# ------------------------------------------------------------
# GITHUB INTEGRATION
# ------------------------------------------------------------
GITHUBTOKEN=github_pat_...
GITHUB_WEBHOOK_SECRET=

# ------------------------------------------------------------
# CLOUDFLARE INTEGRATION
# ------------------------------------------------------------
CLOUDFLARETOKEN=

# ------------------------------------------------------------
# GCP INTEGRATION
# ------------------------------------------------------------
GCP_PROJECT_ID=your-project-id
GCP_SA_KEY_JSON=

# ------------------------------------------------------------
# CONTAINERS
# ------------------------------------------------------------
DOCKER_REGISTRY=ghcr.io/your-org/sentinelai
DOCKER_IMAGE_TAG=latest

# ------------------------------------------------------------
# GENERAL
# ------------------------------------------------------------
NODE_ENV=development
