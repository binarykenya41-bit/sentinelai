# =============================================================
# Sentinel AI — Database Environment Variables
# Copy to .env.local (frontend) and .env (backend) — never commit real values
# =============================================================

# --- Supabase (PostgreSQL) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct PostgreSQL connection (for migrations / server-side)
DATABASE_URL=postgresql://postgres:[password]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# --- Neo4j (Attack Graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# --- Redis (Cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=false
