# ─── Logistics Industry Stack — Environment Variables ────────────────────────
# Copy to .env and fill in any overrides.
# Defaults are set for local development / demo.

# ── ERPNext ──────────────────────────────────────────────────────────────────
ERPNEXT_VERSION=v15.51.2
MYSQL_ROOT_PASSWORD=erpnext_root
ERPNEXT_ADMIN_PASSWORD=admin

# ── PostgreSQL (shipment DB) ─────────────────────────────────────────────────
PG_USER=logistics
PG_PASSWORD=logistics_pass

# ── GitLab ───────────────────────────────────────────────────────────────────
# Initial root password (GitLab enforces min 8 chars with complexity)
GITLAB_ROOT_PASSWORD=SentinelLogistics!

# ── Grafana ──────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
